# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API

# Public URL and anon key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — NEVER expose this to the browser.
# Used server-side to bypass Row Level Security on the manual_events table.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── evento.so ─────────────────────────────────────────────────────────────────
# Your evento.so username (visible in your profile URL: evento.so/username).
# No API key required — the Embed API is public.
EVENTO_SO_USERNAME=your_username

# ── Admin ─────────────────────────────────────────────────────────────────────
# Password required to add, edit, or delete manual events via the admin modal.
# Choose something strong — this is the only protection on write operations.
ADMIN_PASSWORD=your-strong-password-here
